{
  "name": "vscode-docs-bar",
  "displayName": "Docs Bar",
  "description": "A Notion-style Markdown navigator for VS Code: emoji page icons, display-name aliases, custom drag sort, hidden entries, git status — in a webview sidebar beside the built-in Explorer.",
  "version": "0.2.0",
  "publisher": "eleveian011",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/eleveian011/vscode-docs-bar.git"
  },
  "engines": {
    "vscode": "^1.84.0"
  },
  "categories": [
    "Other"
  ],
  "keywords": [
    "markdown",
    "notion",
    "emoji",
    "notes",
    "sidebar"
  ],
  "main": "./dist/extension.js",
  "activationEvents": [
    "onStartupFinished"
  ],
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "docsBarContainer",
          "title": "Docs Bar",
          "icon": "media/icon.svg"
        }
      ]
    },
    "views": {
      "docsBarContainer": [
        {
          "id": "docsBar",
          "name": "Docs",
          "type": "webview"
        }
      ]
    },
    "commands": [
      {
        "command": "docsBar.newFile",
        "title": "Docs Bar: 新建文件",
        "icon": "$(new-file)"
      },
      {
        "command": "docsBar.newFolder",
        "title": "Docs Bar: 新建目录",
        "icon": "$(new-folder)"
      },
      {
        "command": "docsBar.expandAll",
        "title": "Docs Bar: 全部展开",
        "icon": "$(expand-all)"
      },
      {
        "command": "docsBar.collapseAll",
        "title": "Docs Bar: 全部收起",
        "icon": "$(collapse-all)"
      },
      {
        "command": "docsBar.refresh",
        "title": "Docs Bar: 刷新",
        "icon": "$(refresh)"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "docsBar.newFile",
          "when": "view == docsBar",
          "group": "navigation@1"
        },
        {
          "command": "docsBar.newFolder",
          "when": "view == docsBar",
          "group": "navigation@2"
        },
        {
          "command": "docsBar.expandAll",
          "when": "view == docsBar",
          "group": "navigation@3"
        },
        {
          "command": "docsBar.collapseAll",
          "when": "view == docsBar",
          "group": "navigation@4"
        },
        {
          "command": "docsBar.refresh",
          "when": "view == docsBar",
          "group": "navigation@5"
        }
      ]
    },
    "configuration": {
      "title": "Docs Bar",
      "properties": {
        "docsBar.root": {
          "type": "string",
          "default": "",
          "description": "Docs Bar 的根目录，相对于工作区根。留空则显示整个工作区。例如 \"docs\" 只显示 docs 目录。"
        },
        "docsBar.markdownOnly": {
          "type": "boolean",
          "default": true,
          "description": "只显示 Markdown 文件与包含 Markdown 的目录（隐藏其他文件和空目录）。"
        },
        "docsBar.stripMarkdownExtension": {
          "type": "boolean",
          "default": true,
          "description": "在列表中隐藏 .md / .markdown 后缀（Notion 风格）。"
        },
        "docsBar.icons": {
          "type": "object",
          "default": {},
          "additionalProperties": {
            "type": "string"
          },
          "description": "路径 → emoji 图标映射。一般通过右键菜单维护。"
        },
        "docsBar.aliases": {
          "type": "object",
          "default": {},
          "additionalProperties": {
            "type": "string"
          },
          "description": "路径 → 显示名映射（不改真实文件名）。一般通过右键菜单维护。"
        },
        "docsBar.order": {
          "type": "object",
          "default": {},
          "additionalProperties": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "description": "每个父目录下子项的手动排序。一般通过拖拽维护。"
        },
        "docsBar.hidden": {
          "type": "array",
          "default": [],
          "items": {
            "type": "string"
          },
          "description": "在 Docs Bar 中隐藏的路径列表（相对工作区根）。"
        },
        "docsBar.alwaysHide": {
          "type": "array",
          "default": [
            ".git",
            ".DS_Store",
            "node_modules"
          ],
          "items": {
            "type": "string"
          },
          "description": "始终隐藏的文件/目录名（按 basename 匹配）。"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run build",
    "build": "node esbuild.mjs --production",
    "watch": "node esbuild.mjs --watch",
    "check": "tsc --noEmit",
    "package": "npx --yes @vscode/vsce package --no-dependencies"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "@types/vscode": "^1.84.0",
    "esbuild": "^0.23.0",
    "typescript": "^5.5.0",
    "unicode-emoji-json": "^0.9.0"
  }
}
