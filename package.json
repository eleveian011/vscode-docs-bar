{
  "name": "vscode-docs-bar",
  "displayName": "Docs Bar",
  "description": "A Notion-style Markdown navigator for VS Code: emoji page icons, display-name aliases, custom drag sort, hidden entries, git status — in a webview sidebar beside the built-in Explorer.",
  "version": "0.3.0",
  "publisher": "eleveian011",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/eleveian011/vscode-docs-bar.git"
  },
  "engines": {
    "vscode": "^1.84.0"
  },
  "categories": [
    "Other"
  ],
  "keywords": [
    "markdown",
    "notion",
    "emoji",
    "notes",
    "sidebar"
  ],
  "main": "./dist/extension.js",
  "activationEvents": [
    "onStartupFinished"
  ],
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        { "id": "docsBarContainer", "title": "Docs Bar", "icon": "media/icon.svg" }
      ]
    },
    "views": {
      "docsBarContainer": [
        { "id": "docsBar", "name": "Docs", "type": "webview" }
      ]
    },
    "commands": [
      { "command": "docsBar.newFile", "title": "Docs Bar: 新建文件", "icon": { "light": "media/lucide/newfile-light.svg", "dark": "media/lucide/newfile-dark.svg" } },
      { "command": "docsBar.newFolder", "title": "Docs Bar: 新建目录", "icon": { "light": "media/lucide/newfolder-light.svg", "dark": "media/lucide/newfolder-dark.svg" } },
      { "command": "docsBar.expandAll", "title": "Docs Bar: 全部展开", "icon": { "light": "media/lucide/expand-light.svg", "dark": "media/lucide/expand-dark.svg" } },
      { "command": "docsBar.collapseAll", "title": "Docs Bar: 全部收起", "icon": { "light": "media/lucide/collapse-light.svg", "dark": "media/lucide/collapse-dark.svg" } },
      { "command": "docsBar.refresh", "title": "Docs Bar: 刷新", "icon": { "light": "media/lucide/refresh-light.svg", "dark": "media/lucide/refresh-dark.svg" } },
      { "command": "docsBar.ctx.open", "title": "打开" },
      { "command": "docsBar.ctx.newFile", "title": "新建文件" },
      { "command": "docsBar.ctx.newFolder", "title": "新建目录" },
      { "command": "docsBar.ctx.setIcon", "title": "设置图标…" },
      { "command": "docsBar.ctx.setAlias", "title": "设置显示名…" },
      { "command": "docsBar.ctx.rename", "title": "重命名" },
      { "command": "docsBar.ctx.duplicate", "title": "创建副本" },
      { "command": "docsBar.ctx.copy", "title": "复制" },
      { "command": "docsBar.ctx.paste", "title": "粘贴" },
      { "command": "docsBar.ctx.copyPath", "title": "复制路径" },
      { "command": "docsBar.ctx.copyRelativePath", "title": "复制相对路径" },
      { "command": "docsBar.ctx.hide", "title": "在 Docs Bar 中隐藏" },
      { "command": "docsBar.ctx.reveal", "title": "在 Finder 中显示" },
      { "command": "docsBar.ctx.delete", "title": "删除" }
    ],
    "menus": {
      "view/title": [
        { "command": "docsBar.newFile", "when": "view == docsBar", "group": "navigation@1" },
        { "command": "docsBar.newFolder", "when": "view == docsBar", "group": "navigation@2" },
        { "command": "docsBar.expandAll", "when": "view == docsBar", "group": "navigation@3" },
        { "command": "docsBar.collapseAll", "when": "view == docsBar", "group": "navigation@4" },
        { "command": "docsBar.refresh", "when": "view == docsBar", "group": "navigation@5" }
      ],
      "webview/context": [
        { "command": "docsBar.ctx.open", "when": "webviewSection == 'docsBarItem' && !docIsDir", "group": "1_open@1" },
        { "command": "docsBar.ctx.newFile", "when": "webviewSection == 'docsBarItem' && docIsDir", "group": "1_open@1" },
        { "command": "docsBar.ctx.newFolder", "when": "webviewSection == 'docsBarItem' && docIsDir", "group": "1_open@2" },
        { "command": "docsBar.ctx.setIcon", "when": "webviewSection == 'docsBarItem'", "group": "2_icon@1" },
        { "command": "docsBar.ctx.setAlias", "when": "webviewSection == 'docsBarItem'", "group": "2_icon@2" },
        { "command": "docsBar.ctx.rename", "when": "webviewSection == 'docsBarItem'", "group": "3_mod@1" },
        { "command": "docsBar.ctx.duplicate", "when": "webviewSection == 'docsBarItem'", "group": "3_mod@2" },
        { "command": "docsBar.ctx.copy", "when": "webviewSection == 'docsBarItem'", "group": "3_mod@3" },
        { "command": "docsBar.ctx.paste", "when": "webviewSection == 'docsBarItem' && docIsDir", "group": "3_mod@4" },
        { "command": "docsBar.ctx.copyPath", "when": "webviewSection == 'docsBarItem'", "group": "4_path@1" },
        { "command": "docsBar.ctx.copyRelativePath", "when": "webviewSection == 'docsBarItem'", "group": "4_path@2" },
        { "command": "docsBar.ctx.hide", "when": "webviewSection == 'docsBarItem'", "group": "5_more@1" },
        { "command": "docsBar.ctx.reveal", "when": "webviewSection == 'docsBarItem'", "group": "5_more@2" },
        { "command": "docsBar.ctx.delete", "when": "webviewSection == 'docsBarItem'", "group": "9_danger@1" }
      ],
      "commandPalette": [
        { "command": "docsBar.ctx.open", "when": "false" },
        { "command": "docsBar.ctx.newFile", "when": "false" },
        { "command": "docsBar.ctx.newFolder", "when": "false" },
        { "command": "docsBar.ctx.setIcon", "when": "false" },
        { "command": "docsBar.ctx.setAlias", "when": "false" },
        { "command": "docsBar.ctx.rename", "when": "false" },
        { "command": "docsBar.ctx.duplicate", "when": "false" },
        { "command": "docsBar.ctx.copy", "when": "false" },
        { "command": "docsBar.ctx.paste", "when": "false" },
        { "command": "docsBar.ctx.copyPath", "when": "false" },
        { "command": "docsBar.ctx.copyRelativePath", "when": "false" },
        { "command": "docsBar.ctx.hide", "when": "false" },
        { "command": "docsBar.ctx.reveal", "when": "false" },
        { "command": "docsBar.ctx.delete", "when": "false" }
      ]
    },
    "configuration": {
      "title": "Docs Bar",
      "properties": {
        "docsBar.root": {
          "type": "string",
          "default": "",
          "description": "Docs Bar 的根目录，相对于工作区根。留空则显示整个工作区。例如 \"docs\" 只显示 docs 目录。"
        },
        "docsBar.markdownOnly": {
          "type": "boolean",
          "default": true,
          "description": "只显示 Markdown 文件与包含 Markdown 的目录（隐藏其他文件和空目录）。"
        },
        "docsBar.stripMarkdownExtension": {
          "type": "boolean",
          "default": true,
          "description": "在列表中隐藏 .md / .markdown 后缀（Notion 风格）。"
        },
        "docsBar.icons": {
          "type": "object",
          "default": {},
          "additionalProperties": { "type": "string" },
          "description": "路径 → emoji 图标映射。一般通过右键菜单维护。"
        },
        "docsBar.aliases": {
          "type": "object",
          "default": {},
          "additionalProperties": { "type": "string" },
          "description": "路径 → 显示名映射（不改真实文件名）。一般通过右键菜单维护。"
        },
        "docsBar.order": {
          "type": "object",
          "default": {},
          "additionalProperties": { "type": "array", "items": { "type": "string" } },
          "description": "每个父目录下子项的手动排序。一般通过拖拽维护。"
        },
        "docsBar.hidden": {
          "type": "array",
          "default": [],
          "items": { "type": "string" },
          "description": "在 Docs Bar 中隐藏的路径列表（相对工作区根）。"
        },
        "docsBar.alwaysHide": {
          "type": "array",
          "default": [ ".git", ".DS_Store", "node_modules" ],
          "items": { "type": "string" },
          "description": "始终隐藏的文件/目录名（按 basename 匹配）。"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run build",
    "build": "node esbuild.mjs --production",
    "watch": "node esbuild.mjs --watch",
    "check": "tsc --noEmit",
    "package": "npx --yes @vscode/vsce package --no-dependencies"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "@types/vscode": "^1.84.0",
    "esbuild": "^0.23.0",
    "lucide-static": "^1.0.0",
    "typescript": "^5.5.0",
    "unicode-emoji-json": "^0.9.0"
  }
}
